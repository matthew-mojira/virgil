//@execute =54

// Direct reproduction of the stale-spill-width hazard using CiTest.forceSpill.
// `#no-inline` is load-bearing: at -O3 the optimizer inlines call1 into main
// otherwise, eliminating the separate-frame reuse this depends on. Fails
// identically at -O2 and -O3 (GlobalRegAlloc); -O0 needs a different
// construction (see forcespill_stale_width01.v3), and -O1 (LocalRegAlloc) is
// immune. The for-loop below (rather than a single `r[0]` read) is
// load-bearing too: it's the difference between hitting -O3 and not --
// removing it still reproduces at -O2 but no longer at -O3, since it changes
// the register pressure/frame size just enough to move the two forced spills
// off the same stack address (see stale_spill_width01/02.v3 for the same
// heisenbug sensitivity in the original, non-forceSpill-based tests).
//
// `call1` force-spills a poison `long` (0x1122334455667788) as its only
// operation. `probe` force-spills its `off` parameter, then slices `buf[off
// ... off+4]` -- Range<byte> construction is the only ordinary, memory-safe
// Virgil construct that emits a literal PtrAdd(pointer, int); plain array
// indexing folds the whole address computation into one hardware-addressed
// load and never exposes a bare wide add. Both functions are called
// sequentially (never nested) from `main`, so `probe`'s frame reuses the
// exact stack address `call1`'s frame just vacated (LIFO reuse): `off`'s
// spill slot only ever gets a 4-byte store, so its high 4 bytes survive from
// call1's poison write, corrupting the slice's base pointer.
def call1(poison: long) -> long #no-inline {
	return CiTest.forceSpill(poison); // writes poison's 8 bytes into the shared slot
}

def probe(off: int) -> int {
	var buf: Array<byte> = [10, 11, 12, 13, 14, 15, 16, 17];
	var o = CiTest.forceSpill(off); // overwrites only the low 4 bytes of that same slot
	var r = buf[o ... o + 4]; // the wide pointer+offset op
	var sum = 0;
	for (b in r) sum = sum + b;
	return sum;
}

def main() -> int {
	call1(0x1122334455667788L);
	return probe(2);
}
